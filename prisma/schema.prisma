// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PATIENT
  DOCTOR
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id        String           @id @default(cuid())
  clerkId   String           @unique
  email     String           @unique
  firstName String?
  lastName  String?
  phone     String?
  role      UserRole         @default(PATIENT)
  plan      SubscriptionPlan @default(FREE)
  gender    Gender?
  birthDate DateTime?
  birthPlace String?
  address    String?
  nationality String?        @default("Béninoise")
  emergencyContactName String?
  emergencyContactPhone String?
  exportPin String? // Code PIN pour l'export du carnet
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Profil Santé (Patient)
  pseudo          String?
  age             Int?
  bloodGroup      BloodGroup?
  allergies       String?
  electrophoresis String?
  chronicDiseases String?
  vaccines        String?
  weight          Float? // kg

  // relationships
  appointments         Appointment[]
  notifications        Notification[]
  treatments           Treatment[]
  healthAccessRequests HealthAccessRequest[]
  doctorProfile        Doctor?
  securityAuditLogs    SecurityAuditLog[]
  recentPatients       RecentPatient[]
  qrTokens             QRToken[]

  @@map("users")
}

model Doctor {
  id              String  @id @default(cuid())
  userId          String  @unique
  clerkId         String? @unique
  name            String
  firstName       String?
  lastName        String?
  email           String  @unique
  phone           String
  speciality      String
  practiceAddress String?
  cabinetInfo     String?
  bio             String?
  imageUrl        String
  gender          Gender
  isActive        Boolean @default(true)

  // Nouveaux champs pour la dynamisation
  basePrice            Float?  @default(0) // Tarif de base de la consultation
  availableDays        String? // Jours dispo (ex: "Lundi,Mardi,Mercredi")
  workingHoursStart    String? @default("09:00")
  workingHoursEnd      String? @default("18:00")
  consultationDuration Int     @default(30) // Durée standard par défaut

  // Certification Professionnelle (Admin Validation required)
  licenseNumber       String             @unique
  verificationStatus  VerificationStatus @default(PENDING)
  professionalCardUrl String? // Image/PDF scan
  cipCardUrl          String? // Certificat d'Identification Personnelle
  signedContractUrl   String? // Contrat signé
  workplaceType       String? // Cabinet, Hôpital, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relationships
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments         Appointment[]
  healthAccessRequests HealthAccessRequest[]
  prescribedTreatments Treatment[]           @relation("PrescribingDoctor")
  recentPatients       RecentPatient[]

  @@map("doctors")
}

enum AppointmentStatus {
 CONFIRMED
 COMPLETED
 CANCELLED
 REQUESTED_RESCHEDULE
}

enum RescheduleBy {
  PATIENT
  DOCTOR
}

enum AppointmentType {
  IN_PERSON
  ONLINE
}

model Appointment {
  id               String            @id @default(cuid())
  date             DateTime
  time             String // store time as string i.e. 14:30
  duration         Int               @default(30) // duration in minutes
  price            Float? // Prix payé/dû pour la séance. Sera défini par le docteur.
  status           AppointmentStatus @default(CONFIRMED)
  type             AppointmentType   @default(IN_PERSON)
  notes            String?
  reason           String? // reason for appointment - teeth cleaning? emergency visit? etc.
  summary          String? // Résumé de la consultation après la session
  proposedDate     DateTime?
  proposedTime     String?
  proposedBy       RescheduleBy?
  rescheduleReason String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // foreign keys
  userId   String
  doctorId String?

  // relationships
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor Doctor? @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("appointments")
}

enum NotificationType {
  RESCHEDULE_REQUEST
  RESCHEDULE_RESPONSE
  APPOINTMENT_CONFIRMED
  HEALTH_ACCESS
  GENERAL
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(GENERAL)
  title     String
  content   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Treatment {
  id                  String   @id @default(cuid())
  userId              String
  name                String
  dosage              String
  frequency           String // ex: "1x/jour", "2x/jour"
  time                String // Heure(s) de prise (ex: "08:00, 20:00")
  duration            Int? // Durée en jours
  pathology           String? // pathologie / motif
  administrationRoute String? // voie d'administration
  notes               String?
  prescriptionUrl     String? // Pour stocker l'image/scan (base64 ou URL)
  isActive            Boolean  @default(true)
  prescribingDoctorId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescribingDoctor Doctor?        @relation("PrescribingDoctor", fields: [prescribingDoctorId], references: [id], onDelete: SetNull)
  logs              TreatmentLog[]

  @@map("treatments")
}

model TreatmentLog {
  id          String   @id @default(cuid())
  treatmentId String
  takenAt     DateTime @default(now())

  treatment Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@map("treatment_logs")
}

model HealthAccessRequest {
  id        String       @id @default(cuid())
  userId    String
  doctorId  String
  status    AccessStatus @default(PENDING)
  expiresAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([userId, doctorId])
  @@map("health_access_requests")
}

model RecentPatient {
  id             String   @id @default(cuid())
  doctorId       String
  patientId      String
  lastAccessedAt DateTime @default(now())
  
  doctor         Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([doctorId, patientId]) 
  @@index([doctorId, lastAccessedAt])

  @@map("recent_patients")
}

model QRToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("qr_tokens")
}

model SecurityAuditLog {
  id         String   @id @default(cuid())
  userId     String
  accessedBy String // ClerkId ou ID médecin/admin
  action     String // ex: "VIEW_HEALTH_DATA", "EXPORT_PDF"
  targetId   String // ex: patientId ou appointmentId
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("security_audit_logs")
}

enum Gender {
  MALE
  FEMALE
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum AccessStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}
